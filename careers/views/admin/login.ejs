<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | Smaatech Careers</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; font-family: 'Inter', sans-serif; color: white; }
        .glass-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen">
    <div class="glass-card p-10 rounded-2xl w-full max-w-md shadow-2xl">
        <div class="text-center mb-8">
            <p class="text-[11px] font-bold uppercase tracking-[0.28em] text-emerald-400 mb-3">Private Access</p>
            <h2 class="text-3xl font-black mb-2">Hiring Admin Portal</h2>
            <p class="text-slate-400">Secure login for career management. Public visitors can open this page, but only authorized client credentials can enter the dashboard.</p>
        </div>
        
        <% if (error) { %>
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl mb-6 text-sm text-center font-bold">
                <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST" class="space-y-6">
            <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Email / Username</label>
                <input type="text" name="username" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 focus:outline-none focus:border-emerald-500/50 transition-all">
            </div>
            <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Password</label>
                <input type="password" name="password" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 focus:outline-none focus:border-emerald-500/50 transition-all">
            </div>
            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-slate-900 font-bold py-4 rounded-xl shadow-lg transition-all transform hover:-translate-y-1">
                Access Dashboard
            </button>
        </form>

        <div class="mt-6 text-center text-sm text-slate-500">
            <a href="/career" class="hover:text-white transition-colors">Back to Careers Page</a>
        </div>
    </div>
</body>
</html>
